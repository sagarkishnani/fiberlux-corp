---
import { client } from "../../../tina/__generated__/client";
import BeneficiosReact from "./BeneficiosReact.tsx";

interface Props {
  relativePath: string;
}

const { relativePath } = Astro.props;
const subQuery = await client.queries.subservicio({ relativePath });
---

<BeneficiosReact
  client:visible
  query={subQuery.query}
  variables={subQuery.variables}
  data={subQuery.data}
/>
