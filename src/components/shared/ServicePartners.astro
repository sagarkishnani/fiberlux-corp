---
import { client } from "../../../tina/__generated__/client";
import ServicePartnersReact from "./ServicePartnersReact.tsx";

interface Props {
  relativePath: string;
}
const { relativePath } = Astro.props;

const serviceQuery = await client.queries.service({ relativePath });
---

<ServicePartnersReact
  client:visible
  query={serviceQuery.query}
  variables={serviceQuery.variables}
  data={serviceQuery.data}
/>
