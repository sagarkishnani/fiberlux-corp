---
/**
 * LegalPage — resolves a `legal` collection doc by slug and renders it.
 * Content via LegalPageReact; the embedded form (if any) is added in a later step.
 */
import { client } from "../../../tina/__generated__/client";
import LegalPageReact from "./LegalPageReact.tsx";
import DynamicForm from "../dynamic-form/DynamicForm.astro";

interface Props {
  slug: string;
}

const { slug } = Astro.props;

const result = await client.queries.legal({ relativePath: `${slug}.json` });
const embeddedFormSlug = result.data?.legal?.embeddedFormSlug;
---

<section style={{ backgroundColor: "#ffffff" }}>
  <LegalPageReact
    client:load
    query={result.query}
    variables={result.variables}
    data={result.data}
  />

  {
    embeddedFormSlug && (
      <div
        style={{
          maxWidth: "820px",
          margin: "0 auto",
          padding: "8px 24px 80px",
          fontFamily: "Poppins, sans-serif",
        }}
      >
        <DynamicForm formSlug={embeddedFormSlug} />
      </div>
    )
  }
</section>
