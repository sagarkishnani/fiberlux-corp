---
/**
 * BannerApp — banner promocional reutilizable de la Fiberlux App (SPEC 53).
 * Se alimenta del objeto `banner` de la colección `fiberluxApp`. Reutilizable:
 * insértalo en cualquier página con `<BannerApp />`.
 */
import { client } from "../../../tina/__generated__/client";
import BannerAppReact from "./BannerAppReact.tsx";

const appQuery = await client.queries.fiberluxApp({
  relativePath: "index.json",
});
---

<BannerAppReact
  client:visible
  query={appQuery.query}
  variables={appQuery.variables}
  data={appQuery.data}
/>
