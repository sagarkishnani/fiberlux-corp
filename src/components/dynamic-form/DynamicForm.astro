---
import client from "../../../tina/__generated__/client";
import DynamicFormReact from "./DynamicFormReact";

interface Props {
  formSlug: string;
  prefill?: Record<string, string>;
}

const { formSlug, prefill } = Astro.props;

const result = await client.queries.dynamicForms({
  relativePath: `${formSlug}.json`,
});
---

<DynamicFormReact
  query={result.query}
  variables={result.variables}
  data={result.data}
  prefill={prefill}
  client:load
/>
