---
/**
 * BlogPreview wrapper — fetches home data + blog posts from TinaCMS
 * Uses client:visible for carousel JS interaction
 *
 * SPEC 63: si recibe `tags` (los `blogTags` de la página), muestra los posts
 * cuyos tags intersecten esa lista; si no hay coincidencias (o no vienen `tags`),
 * muestra los 6 más recientes. Home / fiberlux-app no pasan `tags` → recientes.
 */
import { client } from '../../../tina/__generated__/client';
import BlogPreviewReact from './BlogPreviewReact.tsx';

interface Props {
  tags?: (string | null)[] | null;
}

const { tags } = Astro.props;
const wanted = (tags || []).filter(Boolean) as string[];

const homeQuery = await client.queries.home({ relativePath: 'index.json' });

let allEdges: any[] = [];
try {
  const postsQuery = await client.queries.postConnection({
    first: 50,
    sort: 'date',
  });
  allEdges = postsQuery.data?.postConnection?.edges || [];
} catch {
  allEdges = [];
}

// Orden por fecha descendente (más recientes primero), independiente del sort de Tina.
const byDateDesc = [...allEdges].sort((a, b) => {
  const da = new Date(a?.node?.date || 0).getTime();
  const db = new Date(b?.node?.date || 0).getTime();
  return db - da;
});

// Filtra por intersección de tags si vienen; si el filtro queda vacío, recientes.
let posts = byDateDesc;
if (wanted.length > 0) {
  const filtered = byDateDesc.filter((e) => {
    const postTags = (e?.node?.tags || []).filter(Boolean) as string[];
    return postTags.some((t) => wanted.includes(t));
  });
  posts = filtered.length > 0 ? filtered : byDateDesc;
}
posts = posts.slice(0, 6);
---

<BlogPreviewReact
  client:visible
  query={homeQuery.query}
  variables={homeQuery.variables}
  data={homeQuery.data}
  posts={posts}
/>
