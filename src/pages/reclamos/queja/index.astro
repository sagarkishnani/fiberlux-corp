---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import DynamicForm from "../../../components/dynamic-form/DynamicForm.astro";
---

<BaseLayout
  title="Formulario de Queja"
  description="Interponga su queja por transgresión de normas de procedimiento."
  headerTheme="light"
>
  <main>
    <section style={{ padding: "64px 0 80px", backgroundColor: "#ffffff" }}>
      <div
        style={{
          maxWidth: "800px",
          margin: "0 auto",
          padding: "0 24px",
          fontFamily: "Poppins, sans-serif",
        }}
      >
        <DynamicForm formSlug="queja" />
      </div>
    </section>
  </main>
</BaseLayout>
