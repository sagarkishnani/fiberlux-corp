---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { client } from "../../../tina/__generated__/client";
import HeroSolucion from "../../components/servicios/HeroSolucion.astro";
import ValorSolucion from "../../components/servicios/ValorSolucion.astro";
import Partners from "../../components/shared/Partners.astro";
import CatalogoSoluciones from "../../components/servicios/CatalogoSoluciones.astro";
import Stats from "../../components/Stats.astro";
import ServiciosForm from "../../components/servicios/ServiciosForm.astro";
import BlogPreview from "../../components/blog/BlogPreview.astro";
import FaqSolucion from "../../components/servicios/FaqSolucion.astro";

/* ── Static paths from all solution documents ── */
export async function getStaticPaths() {
  let paths: { params: { solucion: string } }[] = [];
  try {
    const conn = await client.queries.serviceConnection({ last: 100 });
    const edges = conn.data?.serviceConnection?.edges || [];
    paths = edges
      .filter((e: any) => e?.node)
      .map((e: any) => ({ params: { solucion: e!.node!._sys.filename } }));
  } catch {
    paths = [];
  }
  return paths;
}

const { solucion } = Astro.params;
const relativePath = `${solucion}.json`;

/* ── SEO / meta (per-service, falls back to global.seo) ── */
const serviceQuery = await client.queries.service({ relativePath });
const service = serviceQuery.data?.service;

const globalQuery = await client.queries.global({ relativePath: "index.json" });
const globalSeo = globalQuery.data?.global?.seo;

const metaTitle = service?.seo?.metaTitle || service?.title || "Servicios";
const metaDescription =
  service?.seo?.metaDescription || globalSeo?.defaultDescription || undefined;
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  whatsappContext={service?.title ?? undefined}
  whatsappKind="solución"
>
  <main>
    <HeroSolucion relativePath={relativePath} />
    <ValorSolucion relativePath={relativePath} />
    <Partners />
    <CatalogoSoluciones relativePath={relativePath} />
    <div class="-mt-16 relative z-20">
      <Stats title={service?.whyUsTitle ?? undefined} />
    </div>
    <ServiciosForm />
    <div class="-mt-16 relative z-25">
      <BlogPreview />
    </div>
    <FaqSolucion relativePath={relativePath} />
  </main>
</BaseLayout>
