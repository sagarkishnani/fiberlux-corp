---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { client } from "../../../tina/__generated__/client";
import HeroFormasPago from "../../components/formas-de-pago/HeroFormasPago.astro";
import FormasPagoSelector from "../../components/formas-de-pago/FormasPagoSelector.astro";

const formasQuery = await client.queries.formasDePago({
  relativePath: "index.json",
});
const page = formasQuery.data.formasDePago;
const seo = page?.seo;

const title = seo?.metaTitle || page?.heading || "Formas de pago";
const description =
  seo?.metaDescription ||
  "Aprende a pagar tus facturas de Fiberlux desde tu banco de forma sencilla, paso a paso.";
---

<BaseLayout title={title} description={description}>
  <main>
    <HeroFormasPago />
    <FormasPagoSelector />
  </main>
</BaseLayout>
