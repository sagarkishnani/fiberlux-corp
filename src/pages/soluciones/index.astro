---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroServicios from "../../components/servicios/HeroServicios.astro";
// StickyCards: bloque de soluciones anterior (apilamiento sticky). Reemplazado
// por SolucionesSlider (SPEC 35). Se conserva comentado para reutilizarlo luego.
// import StickyCards from "../../components/shared/StickyCards.astro";
import SolucionesSlider from "../../components/shared/SolucionesSlider.astro";
import HomePartners from "../../components/shared/HomePartners.astro";
import CertificacionesSlider from "../../components/certificaciones/CertificacionesSlider.astro";
import ServiciosForm from "../../components/servicios/ServiciosForm.astro";
---

<BaseLayout
  title="Soluciones"
  description="Conoce nuestras soluciones: soluciones tecnológicas de conectividad, ciberseguridad, data center y servicios gestionados respaldadas por la red 100% fibra óptica de Fiberlux Corp."
>
  <main>
    <HeroServicios />
    {/* <StickyCards /> — reemplazado por SolucionesSlider (SPEC 35) */}
    <SolucionesSlider />
    {/* Partners e ISO (certificaciones) reutilizados del home, debajo de las cards */}
    <HomePartners />
    <CertificacionesSlider />
    <ServiciosForm />
  </main>
</BaseLayout>
