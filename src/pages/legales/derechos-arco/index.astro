---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LegalPage from "../../../components/legal/LegalPage.astro";
import { client } from "../../../../tina/__generated__/client";

let seo: any = null;
try {
  const res = await client.queries.legal({ relativePath: "derechos-arco.json" });
  seo = res.data?.legal?.seo || null;
} catch {}
---

<BaseLayout
  title="Manual de derechos ARCO"
  description={seo?.metaDescription ||
    "Ejerce tus derechos de acceso, rectificación, cancelación y oposición (ARCO) sobre tus datos personales en Fiberlux."}
  headerTheme="light"
>
  <main>
    <LegalPage slug="derechos-arco" />
  </main>
</BaseLayout>
