---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroSoporte from "../../components/soporte/HeroSoporte.astro";
import CanalesSoporte from "../../components/soporte/CanalesSoporte.astro";
import SolucionesSlider from "../../components/shared/SolucionesSlider.astro";
import TestimonialSlider from "../../components/shared/TestimonialSlider.astro";
---

<BaseLayout
  title="Soporte técnico"
  description="Contáctate con nuestros ingenieros especializados. Soporte técnico de Fiberlux Corp por WhatsApp, llamada o correo."
>
  <main>
    <HeroSoporte />
    <CanalesSoporte />
    <SolucionesSlider />
    {/* Fondo negro detrás del panel claro de testimonios: sus esquinas superiores
        redondeadas dejan ver este fondo (aquí el <main> no es oscuro como en home). */}
    <div class="-mt-2 relative z-25 bg-greyscale-darkest">
      <TestimonialSlider />
    </div>
  </main>
</BaseLayout>
