      "options": [
        { "value": "telefonia", "label": "Telefonía" },
        { "value": "internet", "label": "Internet" },
        { "value": "otros", "label": "Otros" }
      ]
    },
    {
      "fieldType": "text",
      "name": "otroServicio",
      "label": "Otro servicio (si aplica)",
      "placeholder": "Especifica el servicio",
      "width": "half",
      "order": 20
    },
    {
      "fieldType": "note",
      "noteContent": "Materias Reclamables",
      "order": 21
    },
    {
      "fieldType": "select",
      "name": "materiaReclamo",
      "label": "Materia del reclamo",
      "placeholder": "Selecciona la materia reclamable",
      "required": true,
      "width": "full",
      "order": 22,
      "options": [
        { "value": "facturacion", "label": "Facturación y cobro" },
        { "value": "calidad", "label": "Calidad e idoneidad en la prestación del servicio" },
        { "value": "incumplimiento", "label": "Incumplimiento de condiciones contractuales, ofertas y promociones" },
        { "value": "falta_servicio", "label": "Falta de servicio" },
        { "value": "instalacion", "label": "Instalación, activación o traslado del servicio" },
        { "value": "falta_baja", "label": "Falta de ejecución de baja o suspensión del servicio" },
        { "value": "recargas", "label": "Recargas" },
        { "value": "contratacion_no_solicitada", "label": "Contratación no solicitada" },
        { "value": "migracion", "label": "Migración" },
        { "value": "portabilidad", "label": "Portabilidad" },
        { "value": "otras", "label": "Otras materias reclamables" }
      ]
    },
    {
      "fieldType": "note",
      "noteContent": "Para brindar un mejor servicio se recomienda ingresar el monto del recibo reclamado.",
      "order": 23
    },
    {
      "fieldType": "currency",
      "name": "montoReclamo",
      "label": "Monto del reclamo",
      "width": "full",
      "order": 24
    },
    {
      "fieldType": "textarea",
      "name": "observaciones",
      "label": "Observaciones",
      "placeholder": "Detalla tu reclamo aquí...",
      "required": true,
      "width": "full",
      "order": 25,
      "rows": 4
    },

    {
      "fieldType": "section_header",
      "label": "Documentos adjuntos",
      "sectionNumber": 4,
      "order": 26
    },
    {
      "fieldType": "upload",
      "name": "adjuntos",
      "label": "",
      "width": "full",
      "order": 27,
      "accept": ".pdf,.doc,.docx,.jpg,.png",
      "multiple": true,
      "helpText": "Máximo cinco documentos que no superen 10 Mb en total."
    }
  ]
